.search-section {
  margin-bottom: 20rpx;
}

.search-box {
  padding: 20rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.search-placeholder {
  color: #999999;
  font-size: 28rpx;
}

.scan-icon {
  font-size: 32rpx;
  margin-left: auto;
}

.category-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 30rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.category-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 24rpx;
  color: #333333;
}

.drug-item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.drug-item:last-child {
  border-bottom: none;
}

.drug-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 20rpx;
}

.drug-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.drug-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 6rpx;
}

.drug-spec {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.drug-usage {
  font-size: 24rpx;
  color: #999999;
}

.drug-reminder {
  margin-left: 20rpx;
}

.reminder-text {
  font-size: 24rpx;
  color: #ff4d4f;
  background: #fff1f0;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.common-drug-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.common-drug-item:last-child {
  border-bottom: none;
}

.common-drug-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.common-drug-name {
  font-size: 28rpx;
  color: #333333;
  margin-bottom: 6rpx;
}

.common-drug-desc {
  font-size: 24rpx;
  color: #999999;
}

.common-drug-price {
  font-size: 32rpx;
  font-weight: 600;
  color: #ff4d4f;
}
