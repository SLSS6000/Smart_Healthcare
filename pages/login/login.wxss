.login-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 60rpx;
}

.logo {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.logo-icon {
  position: relative;
  z-index: 3;
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  animation: pulse 2s ease-in-out infinite;
}

.logo-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.logo-ring {
  position: absolute;
  width: 140rpx;
  height: 140rpx;
  border: 3rpx solid #1890ff;
  border-radius: 50%;
  opacity: 0.3;
  animation: ring 3s ease-out infinite;
}

.logo-ring-2 {
  width: 110rpx;
  height: 110rpx;
  border-color: #40a9ff;
  animation-delay: 1s;
  opacity: 0.2;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes ring {
  0% { transform: scale(0.8); opacity: 0.5; }
  50% { opacity: 0.3; }
  100% { transform: scale(1.5); opacity: 0; }
}

.app-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #999999;
}

.login-form {
  padding: 40rpx 30rpx;
}

.form-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  text-align: center;
  margin-bottom: 40rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.input-item {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 24rpx 30rpx;
  margin-bottom: 20rpx;
}

.input-item:last-child {
  margin-bottom: 0;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input-field {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.input-placeholder {
  color: #999999;
}

.eye-icon {
  font-size: 36rpx;
  padding: 10rpx;
}

.form-options {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.checkbox-label {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  color: #666666;
}

.checkbox-label text {
  margin-left: 10rpx;
}

.forgot-password {
  font-size: 26rpx;
  color: #1890ff;
}

.login-btn {
  background: linear-gradient(135deg, #1890ff 0%, #096dd9 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 26rpx;
  border-radius: 50rpx;
  border: none;
  margin-bottom: 30rpx;
}

.login-btn:active {
  opacity: 0.8;
}

.register-link {
  text-align: center;
  font-size: 26rpx;
  color: #666666;
}

.link {
  color: #1890ff;
  margin-left: 10rpx;
}

.other-login {
  margin-top: 60rpx;
  padding: 0 30rpx;
}

.divider {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #e5e5e5;
}

.divider-text {
  font-size: 24rpx;
  color: #999999;
  padding: 0 30rpx;
}

.third-party {
  display: flex;
  justify-content: center;
  gap: 80rpx;
}

.third-party-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.third-icon {
  font-size: 60rpx;
  margin-bottom: 12rpx;
}

.third-party-btn text:last-child {
  font-size: 24rpx;
  color: #666666;
}
