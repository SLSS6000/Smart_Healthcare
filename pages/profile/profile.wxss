.container {
  padding: 0;
  background: radial-gradient(circle at 50% 0%, #e6f7ff 0%, #f8fafc 50%);
  min-height: 100vh;
  position: relative;
}

.main-content {
  padding: 8rpx 30rpx 30rpx;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  animation: fadeIn 0.6s ease-out;
  position: relative;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

/* 玻璃拟态用户卡片 - 极简超薄设计 */
.user-card-new {
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  border-radius: 28rpx;
  padding: 20rpx 28rpx;
  color: #1e293b;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(186, 230, 253, 0.2);
  margin-bottom: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.6);
}

.user-card-new::before {
  content: "";
  position: absolute;
  top: -150rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 50%;
}

.user-avatar-large {
  width: 88rpx;
  height: 88rpx;
  border-radius: 44rpx;
  border: 4rpx solid #ffffff;
  background: #f1f5f9;
}

.user-name-large {
  font-size: 32rpx;
  font-weight: 700;
  color: #0f172a;
}

.greeting-tag {
  font-size: 16rpx;
  background: rgba(14, 165, 233, 0.06);
  color: #0284c7;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  margin-left: 8rpx;
  font-weight: 600;
}

.user-id-text {
  font-size: 18rpx;
  color: #94a3b8;
}

/* 设置按钮 - 移动到右上角 */
.edit-icon-btn.top-right {
  position: absolute;
  top: 30rpx;
  right: 30rpx;
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.4);
  backdrop-filter: blur(8px);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  z-index: 10;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.edit-icon-btn.top-right:active {
  transform: scale(0.9);
  background: rgba(255, 255, 255, 0.6);
}

.health-stats-grid {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(14, 165, 233, 0.04);
}

.stat-num {
  font-size: 30rpx;
  font-weight: 700;
  color: #0f172a;
}

.stat-num.highlight {
  color: #0284c7;
}

.stat-desc {
  font-size: 20rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.score-progress {
  width: 100%;
  height: 4rpx;
  background: rgba(14, 165, 233, 0.06);
  border-radius: 2rpx;
  margin-top: 8rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: #0284c7;
  border-radius: 2rpx;
  transition: width 1s ease-in-out;
}

/* 每日贴士卡片 */
.tip-card {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx;
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
  border-left: 10rpx solid #0284c7;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.02);
}

.tip-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.tip-content {
  flex: 1;
}

.tip-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #0284c7;
  display: block;
  margin-bottom: 4rpx;
}

.tip-text {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.4;
}

/* 打卡卡片 */
.checkin-section {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: linear-gradient(90deg, #0284c7 0%, #0ea5e9 100%);
  padding: 30rpx 40rpx;
  border-radius: 32rpx;
  color: #ffffff;
  margin-bottom: 40rpx;
  box-shadow: 0 10rpx 30rpx rgba(2, 132, 199, 0.2);
}

.checkin-info {
  display: flex;
  flex-direction: column;
}

.checkin-title {
  font-size: 32rpx;
  font-weight: 700;
}

.checkin-desc {
  font-size: 22rpx;
  opacity: 0.8;
  margin-top: 4rpx;
}

.checkin-btn {
  background: #ffffff;
  color: #0284c7;
  font-size: 26rpx;
  font-weight: 700;
  padding: 12rpx 32rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 255, 255, 0.3);
}

.user-text-info {
  flex: 1;
}

.name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name-large {
  font-size: 40rpx;
  font-weight: 700;
}

.greeting-tag {
  font-size: 20rpx;
  background: rgba(255, 255, 255, 0.2);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-left: 16rpx;
  font-weight: 500;
}

.verify-badge {
  width: 28rpx;
  height: 28rpx;
  background: #0ea5e9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 12rpx;
  box-shadow: 0 2rpx 6rpx rgba(14, 165, 233, 0.3);
  flex-shrink: 0;
}

.verify-check {
  color: #ffffff;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 1;
}

.user-id-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* 移除旧的按钮样式 */

.health-stats-grid {
  display: flex;
  justify-content: space-between;
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.15);
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
}

.stat-num.highlight {
  color: #fadb14;
}

.score-box {
  display: flex;
  align-items: baseline;
}

.score-unit {
  font-size: 20rpx;
  margin-left: 4rpx;
}

.stat-box.score-stat {
  position: relative;
  min-width: 140rpx;
}

.score-progress {
  width: 100%;
  height: 6rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 3rpx;
  margin-top: 10rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: #fadb14;
  border-radius: 3rpx;
  transition: width 1s ease-in-out;
}

/* 标题栏 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin: 40rpx 0 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-more {
  font-size: 26rpx;
  color: #64748b;
}

/* 健康网格 */
.health-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.health-card {
  padding: 30rpx;
  border-radius: 30rpx;
  display: flex;
  flex-direction: column;
}

.health-card-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.health-card-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-right: 16rpx;
}

.health-card-label {
  font-size: 26rpx;
  color: #64748b;
  font-weight: 500;
}

.health-card-value {
  display: flex;
  align-items: baseline;
}

.health-card-value .val {
  font-size: 40rpx;
  font-weight: 700;
  color: #1e293b;
}

.health-card-value .unit {
  font-size: 22rpx;
  color: #94a3b8;
  margin-left: 8rpx;
}

/* 设备横向滚动 */
.device-scroll {
  display: flex;
  gap: 24rpx;
  overflow-x: auto;
  padding: 10rpx 0 30rpx;
}

.device-scroll::-webkit-scrollbar {
  display: none;
}

.device-card-new {
  min-width: 280rpx;
  background: #ffffff;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.1);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.device-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.device-type-icon {
  font-size: 40rpx;
}

.battery-tag {
  background: #f1f5f9;
  color: #64748b;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: 600;
}

.battery-tag.low {
  background: #fff1f0;
  color: #f5222d;
}

.device-name-new {
  font-size: 28rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
}

.device-model-new {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  display: block;
}

.device-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.sync-time {
  font-size: 20rpx;
  color: #cbd5e1;
}

.sync-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #cbd5e1;
}

.sync-indicator.online {
  background: #52c41a;
  box-shadow: 0 0 10rpx #52c41a;
}

/* 菜单组 */
.menu-group {
  margin-top: 20rpx;
  padding: 10rpx 30rpx !important;
}

.menu-cell {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.menu-cell:last-child {
  border-bottom: none;
}

.menu-cell-left {
  display: flex;
  align-items: center;
}

.menu-cell-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  margin-right: 24rpx;
}

.menu-cell-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #334155;
}

.menu-cell-right {
  display: flex;
  align-items: center;
}

.menu-cell-hint {
  font-size: 24rpx;
  color: #94a3b8;
  margin-right: 12rpx;
}

.menu-arrow-new {
  font-size: 36rpx;
  color: #cbd5e1;
}

/* 退出登录按钮 */
.logout-section {
  margin: 60rpx 0;
}

.logout-btn-new {
  background: #ffffff;
  color: #64748b;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 30rpx;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 10rpx 30rpx rgba(148, 163, 184, 0.05);
}

/* 编辑弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0, 0, 0, 0.4);
  z-index: 1000;
  backdrop-filter: blur(4px);
}

.edit-modal {
  position: fixed;
  bottom: -100%;
  left: 0;
  width: 100%;
  background: #ffffff;
  border-radius: 40rpx 40rpx 0 0;
  z-index: 1001;
  padding: 40rpx;
  box-sizing: border-box;
  transition: all 0.3s cubic-bezier(0.18, 0.89, 0.32, 1.28);
}

.edit-modal.show {
  bottom: 0;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
}

.modal-close {
  font-size: 40rpx;
  color: #94a3b8;
}

.input-group {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 20rpx;
  display: block;
}

.modal-input {
  background: #f1f5f9;
  padding: 24rpx 30rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  color: #1e293b;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 20rpx;
}

.avatar-option {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid transparent;
  padding: 4rpx;
}

.avatar-option.selected {
  border-color: #1890ff;
  background: #e6f7ff;
}

.modal-footer {
  display: flex;
  gap: 20rpx;
  margin-top: 60rpx;
}

.modal-btn {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  padding: 24rpx 0;
  border-radius: 24rpx;
}

.modal-btn.cancel {
  background: #f1f5f9;
  color: #64748b;
}

.modal-btn.confirm {
  background: #1890ff;
  color: #ffffff;
}

/* 管理员角标 */
.admin-badge {
  display: flex;
  align-items: center;
  background: rgba(15, 23, 42, 0.8);
  color: #ffffff;
  font-size: 18rpx;
  padding: 4rpx 14rpx;
  border-radius: 100rpx;
  margin-left: 16rpx;
  font-weight: 600;
  letter-spacing: 1rpx;
  backdrop-filter: blur(4px);
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.admin-badge-icon {
  font-size: 16rpx;
  margin-right: 6rpx;
}

@keyframes skeleton-loading {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}

.skeleton {
  background: linear-gradient(90deg, #f1f5f9 25%, #e2e8f0 37%, #f1f5f9 63%);
  background-size: 400% 100%;
  animation: skeleton-loading 1.4s ease infinite;
  border-radius: 12rpx;
  color: transparent !important;
}

.skeleton-text {
  height: 32rpx;
  margin-bottom: 12rpx;
  width: 80%;
}

/* 加载动画 */
.loader {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #1890ff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}
