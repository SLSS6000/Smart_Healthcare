<view class="container">
  <view class="doctor-header">
    <view class="doctor-info-card">
      <view class="doctor-avatar-large">
        <image src="{{doctor.avatar}}" class="avatar" mode="aspectFill"></image>
      </view>
      <view class="doctor-main-info">
        <view class="doctor-name-row">
          <text class="doctor-name">{{doctor.name}}</text>
          <text class="doctor-title">{{doctor.title}}</text>
        </view>
        <text class="doctor-department">{{doctor.department}} · {{doctor.hospital}}</text>
        <view class="doctor-stats">
          <view class="stat-item">
            <text class="stat-value">{{doctor.rating}}</text>
            <text class="stat-label">评分</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-value">{{doctor.experience}}</text>
            <text class="stat-label">经验</text>
          </view>
          <view class="stat-divider"></view>
          <view class="stat-item">
            <text class="stat-value">{{doctor.consultCount}}</text>
            <text class="stat-label">咨询量</text>
          </view>
        </view>
      </view>
    </view>
    
    <view class="doctor-tags-card">
      <text class="tags-title">擅长领域</text>
      <view class="tags-wrap">
        <text class="tag" wx:for="{{doctor.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="booking-section">
    <view class="section-header">
      <text class="section-title">选择就诊日期</text>
    </view>
    <view class="date-scroll">
      <scroll-view scroll-x class="date-list" enable-flex>
        <view 
          class="date-item {{selectedDate === item.date ? 'active' : ''}}" 
          wx:for="{{availableDates}}" 
          wx:key="date"
          bindtap="selectDate"
          data-date="{{item.date}}"
        >
          <text class="date-day">{{item.day}}</text>
          <text class="date-week">{{item.week}}</text>
          <view class="date-status" wx:if="{{item.status === 'full'}}">约满</view>
        </view>
      </scroll-view>
    </view>
  </view>

  <view class="booking-section">
    <view class="section-header">
      <text class="section-title">选择就诊时间</text>
      <text class="section-hint">已选日期：{{selectedDate || '请选择日期'}}</text>
    </view>
    <view class="time-grid">
      <view 
        class="time-item {{selectedTime === item ? 'active' : ''}} {{isTimeDisabled(item) ? 'disabled' : ''}}" 
        wx:for="{{availableTimes}}" 
        wx:key="*this"
        bindtap="selectTime"
        data-time="{{item}}"
      >
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <view class="booking-section">
    <view class="section-header">
      <text class="section-title">就诊人信息</text>
    </view>
    <view class="form-card">
      <view class="form-item">
        <text class="form-label">就诊人</text>
        <input 
          class="form-input" 
          placeholder="请输入就诊人姓名" 
          value="{{patientName}}"
          bindinput="onPatientNameInput"
        />
      </view>
      <view class="form-item">
        <text class="form-label">联系电话</text>
        <input 
          class="form-input" 
          placeholder="请输入联系电话" 
          value="{{phone}}"
          bindinput="onPhoneInput"
        />
      </view>
      <view class="form-item">
        <text class="form-label">症状描述</text>
        <textarea 
          class="form-textarea" 
          placeholder="请简要描述您的症状（选填）" 
          value="{{symptoms}}"
          bindinput="onSymptomsInput"
        />
      </view>
    </view>
  </view>

  <view class="bottom-bar">
    <view class="booking-summary">
      <text class="summary-label">预约信息</text>
      <text class="summary-value">{{doctor.name}} · {{selectedDate || '未选日期'}} {{selectedTime || '未选时间'}}</text>
    </view>
    <button class="booking-btn" bindtap="submitBooking">立即预约</button>
  </view>

  <view class="modal-overlay" wx:if="{{showConfirmModal}}" bindtap="closeModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">确认预约</text>
        <view class="modal-close" bindtap="closeModal">×</view>
      </view>
      <view class="modal-body">
        <view class="confirm-info">
          <view class="confirm-row">
            <text class="confirm-label">医生</text>
            <text class="confirm-value">{{doctor.name}} {{doctor.title}}</text>
          </view>
          <view class="confirm-row">
            <text class="confirm-label">科室</text>
            <text class="confirm-value">{{doctor.department}}</text>
          </view>
          <view class="confirm-row">
            <text class="confirm-label">医院</text>
            <text class="confirm-value">{{doctor.hospital}}</text>
          </view>
          <view class="confirm-row">
            <text class="confirm-label">就诊日期</text>
            <text class="confirm-value">{{selectedDate}}</text>
          </view>
          <view class="confirm-row">
            <text class="confirm-label">就诊时间</text>
            <text class="confirm-value">{{selectedTime}}</text>
          </view>
          <view class="confirm-row">
            <text class="confirm-label">就诊人</text>
            <text class="confirm-value">{{patientName}}</text>
          </view>
          <view class="confirm-row">
            <text class="confirm-label">联系电话</text>
            <text class="confirm-value">{{phone}}</text>
          </view>
          <view class="confirm-row" wx:if="{{symptoms}}">
            <text class="confirm-label">症状描述</text>
            <text class="confirm-value">{{symptoms}}</text>
          </view>
        </view>
      </view>
      <view class="modal-footer">
        <button class="btn-cancel" bindtap="closeModal">取消</button>
        <button class="btn-confirm" bindtap="confirmBooking">确认预约</button>
      </view>
    </view>
  </view>
</view>