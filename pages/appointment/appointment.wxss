.container {
  padding: 0;
  background-color: #f8fafc;
  min-height: 100vh;
}

/* 顶部标签页 */
.tabs {
  display: flex;
  background-color: #ffffff;
  padding: 10rpx 40rpx;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #64748b;
  position: relative;
  transition: all 0.3s ease;
}

.tab.active {
  color: #1890ff;
  font-weight: 600;
}

.tab-line {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: linear-gradient(90deg, #1890ff, #69c0ff);
  border-radius: 3rpx;
}

.content-area {
  padding: 20rpx 30rpx;
}

/* 通用卡片样式 */
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 24rpx rgba(148, 163, 184, 0.1);
  border: 1rpx solid rgba(226, 232, 240, 0.8);
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.card-title::before {
  content: "";
  width: 8rpx;
  height: 32rpx;
  background: #1890ff;
  border-radius: 4rpx;
  margin-right: 16rpx;
}

/* 搜索框 */
.search-box {
  padding: 20rpx 30rpx;
}

.search-input {
  display: flex;
  align-items: center;
  background: #f1f5f9;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #94a3b8;
}

.search-placeholder {
  color: #94a3b8;
}

/* 科室网格 */
.dept-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.dept-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: transform 0.2s ease;
}

.dept-item:active {
  transform: scale(0.95);
}

.dept-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.dept-img {
  width: 60rpx;
  height: 60rpx;
}

.dept-emoji {
  font-size: 40rpx;
}

.dept-name {
  font-size: 24rpx;
  color: #334155;
  font-weight: 500;
}

.dept-count {
  font-size: 20rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

/* 医生列表 */
.doctor-item {
  display: flex;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.doctor-item:last-child {
  border-bottom: none;
}

.doctor-avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 55rpx;
  overflow: hidden;
  margin-right: 24rpx;
  background: #f1f5f9;
  flex-shrink: 0;
}

.avatar-img {
  width: 100%;
  height: 100%;
}

.doctor-info {
  flex: 1;
}

.doctor-header {
  margin-bottom: 8rpx;
}

.doctor-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
  margin-right: 12rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #64748b;
  background: #f1f5f9;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.doctor-dept, .doctor-hospital {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.doctor-tags {
  display: flex;
  flex-wrap: wrap;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.08);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  margin-bottom: 8rpx;
}

.doctor-rating {
  text-align: right;
  flex-shrink: 0;
}

.rating-score {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #f59e0b;
}

.rating-count {
  font-size: 20rpx;
  color: #94a3b8;
}

/* 我的预约卡片 */
.appt-card {
  padding: 0;
  overflow: hidden;
}

.appt-header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  border-bottom: 1rpx solid #f1f5f9;
}

.appt-doctor-brief {
  display: flex;
  align-items: center;
}

.appt-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  margin-right: 20rpx;
  background: #f1f5f9;
}

.appt-name-box {
  display: flex;
  flex-direction: column;
}

.appt-doctor-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.appt-doctor-title {
  font-size: 22rpx;
  color: #64748b;
}

.appt-status-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-weight: 500;
}

.appt-body {
  padding: 30rpx;
  background: #fafafa;
}

.appt-detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.appt-detail-row:last-child {
  margin-bottom: 0;
}

.appt-label {
  font-size: 26rpx;
  color: #94a3b8;
}

.appt-value {
  font-size: 26rpx;
  color: #475569;
  font-weight: 500;
}

.appt-value.highlight {
  color: #1890ff;
  font-weight: 600;
}

.appt-footer {
  padding: 20rpx 30rpx;
}

.appt-btns {
  display: flex;
  justify-content: flex-end;
  gap: 20rpx;
}

.btn-outline {
  margin: 0;
  font-size: 24rpx;
  color: #64748b;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  border-radius: 40rpx;
  padding: 0 30rpx;
  line-height: 60rpx;
}

.btn-primary {
  margin: 0;
  font-size: 24rpx;
  color: #ffffff;
  background: #1890ff;
  border-radius: 40rpx;
  padding: 0 30rpx;
  line-height: 60rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-illustration {
  font-size: 120rpx;
  margin-bottom: 40rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #94a3b8;
  text-align: center;
  margin-bottom: 40rpx;
}

.go-booking-btn {
  background: #1890ff;
  color: #ffffff;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0 60rpx;
  line-height: 80rpx;
}

/* 加载与错误 */
.loading, .error {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.loading-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
  animation: rotate 2s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.error-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.retry-btn {
  margin-top: 30rpx;
  font-size: 26rpx;
  background: #f1f5f9;
  color: #64748b;
}

/* 动画 */
.anim-fade-in {
  animation: fadeIn 0.4s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.appt-status {
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.appt-status.status-pending {
  background: #e6f7ff;
  color: #1890ff;
}

.appt-status.status-completed {
  background: #f0fff4;
  color: #52c41a;
}