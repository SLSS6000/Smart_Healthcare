.container {
  min-height: 100vh;
  background-color: #f8fafc;
  padding-bottom: 180rpx;
}

.doctor-header {
  background: linear-gradient(135deg, #1890ff 0%, #69c0ff 100%);
  padding: 40rpx 30rpx;
  padding-bottom: 60rpx;
}

.doctor-info-card {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(24, 144, 255, 0.2);
}

.doctor-avatar-large {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  overflow: hidden;
  background: #f1f5f9;
  margin-right: 30rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.avatar {
  width: 100%;
  height: 100%;
}

.doctor-main-info {
  flex: 1;
}

.doctor-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.doctor-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #1e293b;
  margin-right: 16rpx;
}

.doctor-title {
  font-size: 24rpx;
  color: #fff;
  background: #1890ff;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.doctor-department {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 20rpx;
  display: block;
}

.doctor-stats {
  display: flex;
  align-items: center;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.stat-label {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 4rpx;
}

.stat-divider {
  width: 1rpx;
  height: 40rpx;
  background: #e2e8f0;
}

.doctor-tags-card {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 24rpx 30rpx;
}

.tags-title {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 16rpx;
  display: block;
}

.tags-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #1890ff;
  background: rgba(24, 144, 255, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

.booking-section {
  margin: 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1e293b;
}

.section-hint {
  font-size: 24rpx;
  color: #94a3b8;
}

.date-scroll {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
}

.date-list {
  white-space: nowrap;
}

.date-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 16rpx;
  background: #f8fafc;
  transition: all 0.3s ease;
  position: relative;
}

.date-item.active {
  background: #1890ff;
}

.date-item.active .date-day,
.date-item.active .date-week {
  color: #fff;
}

.date-item.active .date-status {
  color: rgba(255, 255, 255, 0.8);
  background: rgba(255, 255, 255, 0.2);
}

.date-day {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.date-week {
  font-size: 22rpx;
  color: #64748b;
  margin-top: 4rpx;
}

.date-status {
  font-size: 18rpx;
  color: #ff4d4f;
  background: #fff1f0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-top: 8rpx;
}

.time-grid {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.time-item {
  flex: 0 0 calc(25% - 12rpx);
  text-align: center;
  padding: 20rpx 0;
  background: #f8fafc;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #475569;
  transition: all 0.3s ease;
}

.time-item.active {
  background: #1890ff;
  color: #fff;
}

.time-item.disabled {
  background: #f1f5f9;
  color: #cbd5e1;
  pointer-events: none;
}

.form-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
}

.form-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  font-size: 26rpx;
  color: #64748b;
  margin-bottom: 12rpx;
  display: block;
}

.form-input {
  font-size: 28rpx;
  color: #1e293b;
}

.form-textarea {
  font-size: 28rpx;
  color: #1e293b;
  min-height: 120rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.booking-summary {
  flex: 1;
  margin-right: 30rpx;
}

.summary-label {
  font-size: 22rpx;
  color: #94a3b8;
  display: block;
  margin-bottom: 4rpx;
}

.summary-value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.booking-btn {
  background: linear-gradient(135deg, #1890ff 0%, #69c0ff 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  font-size: 30rpx;
  padding: 0 60rpx;
  line-height: 80rpx;
  font-weight: 600;
}

.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 90%;
  max-width: 640rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.modal-close {
  font-size: 48rpx;
  color: #94a3b8;
  line-height: 1;
}

.modal-body {
  padding: 30rpx;
}

.confirm-info {
  background: #f8fafc;
  border-radius: 16rpx;
  padding: 20rpx;
}

.confirm-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.confirm-row:last-child {
  border-bottom: none;
}

.confirm-label {
  font-size: 26rpx;
  color: #64748b;
}

.confirm-value {
  font-size: 26rpx;
  color: #1e293b;
  font-weight: 500;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #f1f5f9;
}

.btn-cancel,
.btn-confirm {
  flex: 1;
  margin: 0;
  padding: 28rpx;
  font-size: 30rpx;
  border-radius: 0;
  border: none;
}

.btn-cancel {
  background: #f8fafc;
  color: #64748b;
}

.btn-confirm {
  background: #1890ff;
  color: #fff;
}