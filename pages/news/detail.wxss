.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.news-detail {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.news-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.category {
  background: #1890ff;
  color: white;
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
}

.time {
  font-size: 24rpx;
  color: #999;
}

.news-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.news-image {
  width: 100%;
  height: 320rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  background: #e6f7ff;
}

.news-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
  margin-bottom: 20rpx;
}

.author {
  font-size: 26rpx;
  color: #666;
}

.stats {
  display: flex;
  gap: 20rpx;
}

.views, .likes {
  font-size: 24rpx;
  color: #999;
}

.news-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  text-indent: 2em;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 300rpx;
  color: #999;
}
