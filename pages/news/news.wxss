.tabs {
  display: flex;
  background: #ffffff;
  padding: 0 20rpx;
  margin-bottom: 30rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  white-space: nowrap;
  border-bottom: 1rpx solid #f1f5f9;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 30rpx;
  color: #64748b;
  position: relative;
  transition: all 0.3s ease;
}

.tab-item.active {
  color: #1890ff;
  font-weight: 600;
}

.tab-item.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 6rpx;
  background: #1890ff;
  border-radius: 3rpx;
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from { width: 0; opacity: 0; }
  to { width: 40rpx; opacity: 1; }
}

.news-card:active .news-card-title {
  color: #1890ff;
}

.news-list {
  padding-bottom: 24rpx;
}

.news-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(24, 144, 255, 0.06);
  transition: all 0.3s ease;
}

.news-card:active {
  transform: scale(0.98);
}

.news-card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.news-category {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.news-time {
  font-size: 24rpx;
  color: #9ca3af;
}

.news-card-content {
  display: flex;
  gap: 24rpx;
}

.news-card-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.news-card-title {
  font-size: 32rpx;
  color: #1f2937;
  font-weight: 600;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.news-card-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 12rpx;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.news-card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}

.news-author {
  font-size: 24rpx;
  color: #9ca3af;
}

.news-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  font-size: 24rpx;
  color: #9ca3af;
}

.news-card-image {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background: linear-gradient(135deg, #e6f7ff 0%, #bae7ff 100%);
  flex-shrink: 0;
}